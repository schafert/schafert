@article{schafer2018american,
  author   = {Schafer, Toryn L. J. and Breck, Stewart W. and Baruch-Mordo, Sharon
              and Lewis, David L. and Wilson, Kenneth R. and Mao, Julie S.
              and Day, Thomas L.},
  title    = {American black bear den-site selection and characteristics in an
              urban environment},
  journal  = {Ursus},
  volume   = {29},
  number   = {1},
  pages    = {25--31},
  year     = {2018},
  doi      = {10.2192/URSUS-D-17-00004.2},
  url      = {https://doi.org/10.2192/URSUS-D-17-00004.2},
  abstract = {Selection of den sites is a crucial aspect of American black bear
              (\textit{Ursus americanus}) life history. High-quality dens provide
              thermal insulation, protection from disturbance, suitable environment
              for parturition and cub development, and proximity to available forage
              upon emergence. Slope was the best predictor of den site selection
              and there was no relationship between den selection and housing
              density, indicating that black bears were neither avoiding nor seeking
              urban areas for denning.}}

