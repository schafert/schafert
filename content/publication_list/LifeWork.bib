@article{owolabi2023role,
  author   = {Owolabi, Olukunle O. and Schafer, Toryn L. J. and Smits, G. E.
              and Sengupta, Sanhita and Ryan, Sean and Wang, Lan
              and Matteson, David S. and Sherman, Mila Getmansky
              and Sunter, Deborah A.},
  title    = {Role of variable renewable energy penetration on electricity price
              and its volatility across independent system operators in the
              {United States}},
  journal  = {Data Science in Science},
  year     = {2023},
  doi      = {10.1080/26941899.2022.2158145},
  url      = {https://doi.org/10.1080/26941899.2022.2158145},
  eprint   = {2112.11338},
  abstract = {The U.S. electrical grid has undergone substantial transformation
              with increased penetration of wind and solar --- forms of variable
              renewable energy (VRE). We examine the role of VRE penetration on
              the system electricity price and price volatility using quantile and
              skew t-distribution regressions. After correcting for temporal effects,
              we observe a decrease in price, with non-linear effects on price
              volatility, for an increase in VRE penetration.}}

